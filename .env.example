# Copy to `.env.local` at this same directory (repo root).
# Convex CLI + Vite apps (web, desktop) read from here.

# --- Convex (CLI) ---
CONVEX_DEPLOYMENT=

# --- Vite (all apps; `envDir` is this folder) ---
VITE_CONVEX_URL=
VITE_PAIRING_ORIGIN=
# Tauri desk only: QR / phone link base when the phone should open the desktop Vite server (port 1420), e.g. `https://YOUR_HOST:1420`. Omit in production (phone uses deployed web origin from VITE_PAIRING_ORIGIN).
# VITE_DESKTOP_PAIRING_ORIGIN=https://YOUR_HOST:1420

# Optional web dev TLS — see README
# VITE_DEV_HTTPS=1
# VITE_DEV_SSL_DOMAINS=

# Optional: hostname you use in the browser (LAN or mDNS, e.g. fiwe-gsg3). Aligns Vite HMR
# with https://that-host:3000 when you are not on localhost.
# VITE_DEV_PUBLIC_HOST=fiwe-gsg3

# Optional desktop download overrides on web landing + desk (defaults: GitHub latest release)
# VITE_DESKTOP_DOWNLOAD_URL=   # legacy: primary button only
# VITE_DESKTOP_WINDOWS_INSTALLER_URL=
# VITE_DESKTOP_WINDOWS_PORTABLE_URL=
# VITE_DESKTOP_MAC_DMG_URL=
