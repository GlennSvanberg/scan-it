# Copy to `.env.local` at this same directory (repo root).
# Convex CLI + all Vite apps (web, desktop, marketing) read from here.

# --- Convex (CLI) ---
CONVEX_DEPLOYMENT=

# --- Vite (all apps; `envDir` is this folder) ---
VITE_CONVEX_URL=
VITE_PAIRING_ORIGIN=

# Optional web dev TLS — see README
# VITE_DEV_HTTPS=1
# VITE_DEV_SSL_DOMAINS=

# Optional: hostname you use in the browser (LAN or mDNS, e.g. fiwe-gsg3). Aligns Vite HMR
# with https://that-host:3000 when you are not on localhost.
# VITE_DEV_PUBLIC_HOST=fiwe-gsg3

# Optional marketing CTAs + web app landing download button
# VITE_WEB_APP_URL=
# VITE_DESKTOP_DOWNLOAD_URL=
