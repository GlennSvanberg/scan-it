{
  "name": "scan-it-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npx convex dev --once && concurrently -r \"npm run dev -w @scan-it/web\" \"npm run dev:convex\"",
    "dev:web": "npm run dev -w @scan-it/web",
    "dev:convex": "npx convex dev",
    "dev:desktop": "npm run dev -w @scan-it/desktop",
    "dev:ts": "tsc -b -w",
    "build": "npm run build -w @scan-it/web",
    "build:web": "npm run build -w @scan-it/web",
    "build:desktop": "npm run tauri:build -w @scan-it/desktop",
    "start": "npm run start -w @scan-it/web",
    "verify": "npm run lint",
    "lint": "npm run build -w @scan-it/web && npm run lint -w @scan-it/desktop && npm exec eslint -- apps/web/src packages/lib/src packages/features/src convex",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.0",
    "@eslint/js": "^9.39.2",
    "@tanstack/eslint-config": "^0.4.0",
    "concurrently": "~9.2.1",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0"
  }
}
