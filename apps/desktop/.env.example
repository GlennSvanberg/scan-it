# Root `.env.local` is always loaded. This file (`apps/desktop/.env.local`) is merged on
# top in `vite.config.ts`, so you can set desktop-only `VITE_*` vars here.
# For phone QR codes in production, VITE_PAIRING_ORIGIN is the deployed web app.
# For Tauri dev only, set VITE_DESKTOP_PAIRING_ORIGIN to your HTTPS desktop dev URL (same host as below, port 1420).

VITE_CONVEX_URL=
VITE_PAIRING_ORIGIN=
# VITE_DESKTOP_PAIRING_ORIGIN=https://YOUR_HOSTNAME:1420
