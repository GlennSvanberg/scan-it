# Vite loads `.env`, `.env.local`, etc. from the monorepo root (`../../`) — you can keep
# a single `.env.local` at the repository root next to `package.json`.

VITE_CONVEX_URL=
# Optional: pairing QR uses this origin for /s/:id (LAN HTTPS, Tailscale hostname, etc.)
VITE_PAIRING_ORIGIN=
# Optional: force dev HTTPS when not using an https:// pairing origin
# VITE_DEV_HTTPS=1
# Optional: extra SANs for the dev TLS cert (comma-separated hosts)
# VITE_DEV_SSL_DOMAINS=host1.example,host2.example
# Optional: hostname you browse with (mDNS/LAN) so Vite HMR matches (no https:// prefix)
# VITE_DEV_PUBLIC_HOST=fiwe-gsg3
# Optional: `/` landing “Download desktop” button (GitHub Release ZIP URL, etc.)
# VITE_DESKTOP_DOWNLOAD_URL=
