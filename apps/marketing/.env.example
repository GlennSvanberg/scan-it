# Loaded from monorepo root `.env*` as well (see vite `envDir`).

# GitHub Release asset for the Windows portable ZIP (marketing "Download" button)
VITE_DESKTOP_DOWNLOAD_URL=https://github.com/GlennSvanberg/scan-it/releases/latest/download/scan-it-windows-portable.zip

# Production URL of the Scan It web app ("Open web app" button)
VITE_WEB_APP_URL=https://your-web-app.vercel.app
